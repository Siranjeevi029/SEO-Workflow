# ============================================================
#  webvory — SEO Content Workflow  ·  environment config
#  Copy to .env and fill. Demo runs on FREE tiers only.
# ============================================================

# --- Runtime mode: "demo" (free stack) or "prod" (paid stack) ---
APP_MODE=demo

# ------------------------------------------------------------
#  DEMO providers (free) — required to run the prototype
# ------------------------------------------------------------
# Groq: free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Firecrawl: free tier key at https://firecrawl.dev
FIRECRAWL_API_KEY=
# If empty, search/scrape falls back to free DuckDuckGo + httpx.

# ------------------------------------------------------------
#  PROD providers (paid) — documented in docs/, not needed for demo
# ------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Pinecone (prod vector store)
PINECONE_API_KEY=
PINECONE_INDEX=webvory-seo

# --- Tracing ---
TRACE_FILE=traces/trace.jsonl
